# SnakeCharmer Configuration
# Copy this file to config.yaml and fill in your credentials.

trakt:
  client_id: YOUR_TRAKT_CLIENT_ID
  client_secret: YOUR_TRAKT_CLIENT_SECRET

  # Username is required for personal/private endpoints (watchlist, auth=true sources)
  username: YOUR_TRAKT_USERNAME

  # Sources to sync from.
  # type values:
  #   watchlist  - Your personal Trakt watchlist (OAuth required)
  #   trending   - Currently trending shows (public)
  #   popular    - Most popular shows (public)
  #   watched    - Most watched shows this week (public)
  #   user_list  - /users/{owner}/lists/{list_slug}/items/shows
  #
  # For type=user_list:
  #   owner/list_slug are required
  #   auth is optional, default false
  #   set auth: true for private/self lists that require OAuth
  # Optional per-source Medusa add options:
  #   quality: Medusa quality preset or individual quality name(s).
  #     Presets: any, sd, hd, hd720p, hd1080p, uhd, uhd4k, uhd8k
  #     Individual: sdtv, sddvd, hdtv, rawhdtv, fullhdtv, hdwebdl,
  #       fullhdwebdl, hdbluray, fullhdbluray, uhd4ktv, uhd4kwebdl,
  #       uhd4kbluray, uhd8ktv, uhd8kwebdl, uhd8kbluray
  #     Can be a single string or a list to combine multiple.
  #   required_words: list of release keywords that must be present.
  sources:
    - type: watchlist
      # medusa:
      #   quality: "any"
      #   required_words: ["2160p", "x265"]
    - type: trending
      # medusa:
      #   quality: ["hd1080p", "uhd4k"]
      #   required_words: ["web-dl"]
    - type: user_list
      owner: giladg
      list_slug: weekly-shows
      # medusa:
      #   required_words: ["proper"]
    - type: user_list
      owner: YOUR_TRAKT_USERNAME
      list_slug: private-favorites
      auth: true
      # medusa:
      #   quality: "hd720p"

  # Max number of shows to fetch from public lists (trending/popular/watched)
  limit: 50

medusa:
  url: http://localhost:8081
  api_key: YOUR_MEDUSA_API_KEY

sync:
  # Set to true to preview changes without adding shows
  dry_run: true

  # Seconds between sync cycles (0 = run once and exit)
  interval: 600

  # Retry settings for transient API failures (connection errors, 5xx, timeouts)
  max_retries: 3        # Max retry attempts (default: 3)
  retry_backoff: 2.0    # Base backoff multiplier in seconds (default: 2.0)

  # Logging format: "text" (human-readable) or "json" (structured JSON lines)
  # JSON format works well with log aggregators like Loki, Promtail, Dozzle
  log_format: text

# Health check endpoint for Docker/monitoring tools (Uptime Kuma, Portainer, etc.)
health:
  enabled: false
  port: 8095

# Web UI for managing configuration via browser
# Enable with config or --webui CLI flag
webui:
  enabled: false
  port: 8089
